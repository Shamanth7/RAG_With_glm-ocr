# ─────────────────────────────────────────────────────
#  Multi-Model RAG — Environment Config
#  Copy this to .env and edit to match your setup
# ─────────────────────────────────────────────────────

# ── Embedding ──────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu        # change to 'cuda' if you have a GPU
EMBED_BATCH=32          # reduce to 8 if running out of memory

# ── Chunking ───────────────────────────────────────
CHUNK_SIZE=512          # tokens per chunk (256 for precise, 1024 for long context)
CHUNK_OVERLAP=64        # token overlap between adjacent chunks

# ── Retrieval ──────────────────────────────────────
TOP_K_DENSE=10          # FAISS candidates before fusion
TOP_K_SPARSE=10         # BM25 candidates before fusion
TOP_K_FINAL=5           # chunks passed to the LLM after re-ranking
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── GLM-OCR Local Server ───────────────────────────
GLM_HOST=http://localhost
GLM_PORT=8000           # ← change this to your GLM-OCR server port
GLM_MODEL=glm-ocr       # model name your server expects
GLM_TIMEOUT=120         # seconds to wait for a response
GLM_MAX_TOKENS=2048
GLM_TEMPERATURE=0.1     # lower = more factual

# ── Offline Mode ───────────────────────────────────
# Set to 1 after first run to prevent any internet access
TRANSFORMERS_OFFLINE=0
